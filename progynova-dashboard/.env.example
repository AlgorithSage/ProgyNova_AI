# Firebase Web SDK config — copy to .env.local and fill from:
# Firebase Console -> Project Settings -> General -> Your apps -> Web app -> SDK setup and configuration (Config)
# These VITE_ vars are exposed to the client (Firebase web keys are safe to expose).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=progynovaai.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=progynovaai
VITE_FIREBASE_STORAGE_BUCKET=progynovaai.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=795092153590
VITE_FIREBASE_APP_ID=

# Backend API (already used by the dashboard)
VITE_API_URL=http://localhost:8000
